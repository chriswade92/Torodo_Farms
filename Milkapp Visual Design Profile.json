        "searchBar": {
          "style": "Rounded edges, subtle shadow",
          "placement": "top",
          "icon": "Search icon at left"
        },
        "citySelector": {
          "style": "Button-like rounded cards",
          "layout": "Flexible, wrapping layout",
          "selectedState": "Highlight using primary or accent colors"
