{
  "designSystem": {
    "style": {
      "theme": "Light, Fresh, Minimalist",
      "colorPalette": {
        "primary": "#64CFF6",
        "secondary": "#FFFFFF",
        "accentColors": ["#FFC700", "#FF5E7E", "#82D173", "#F7A655", "#A97CFF"],
        "background": "#F7FCFE",
        "text": "#333333",
        "subText": "#888888"
      },
      "typography": {
        "fontFamily": "Rounded, Sans-Serif",
        "headingFontWeight": "Bold",
        "bodyFontWeight": "Regular",
