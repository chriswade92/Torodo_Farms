    "structure": {
      "layouts": [
        "Vertical scrolling",
        "Grid-based product cards",
        "Floating action buttons",
        "Search input prominently placed at the top"
      ],
      "navigation": {
        "type": "Bottom Navigation",
        "elements": ["Home", "Alerts", "Profile", "Settings"],
        "style": "Minimalistic icons with labels"
